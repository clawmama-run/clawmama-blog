---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog — ClawMama" description="All ClawMama marketing posts.">
  <h1>Blog archive</h1>
  <p class="muted">All posts are maintained as Markdown or MDX in the repository.</p>

  <div class="post-list">
    {posts.map((post) => (
      <article class="post-card">
        <h2>
          <a href={`/blog/${post.id}`}>{post.data.title}</a>
        </h2>
        <span class="post-meta">
          {new Date(post.data.pubDate).toLocaleDateString()} · {post.data.author}
        </span>
        <p>{post.data.description}</p>
        <div>
          {post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </article>
    ))}
  </div>
</BaseLayout>
