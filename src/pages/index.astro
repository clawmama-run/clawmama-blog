---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const allPosts = (await getCollection("blog")).filter((post) => !post.data.draft);
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const featured = posts[0];
const secondary = posts.slice(1);
---

<BaseLayout
  title="ClawMama Blog — OpenClaw & Hermes hosting playbooks"
  description="Official ClawMama blog for OpenClaw hosting, Hermes hosting, Telegram bot deployment, and managed AI runtime operations."
>
  <section class="blog-hero">
    <div>
      <p class="eyebrow">Official ClawMama Blog</p>
      <h1 class="page-title">OpenClaw and Hermes hosting notes.</h1>
      <p class="hero-copy">
        Practical articles about running Telegram-first AI bots with managed OpenClaw and Hermes runtimes.
      </p>
    </div>
    <a class="button secondary" href="/blog">Browse all articles</a>
  </section>

  {featured ? (
    <section class="featured-section">
      <div class="section-heading">
        <p class="eyebrow">Featured</p>
        <h2>Latest article</h2>
      </div>
      <article class="post-card featured-card">
        <div>
          <div class="tag-row">
            {featured.data.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
          <h3>{featured.data.title}</h3>
          <p>{featured.data.description}</p>
          <span class="post-meta">
            {new Date(featured.data.pubDate).toLocaleDateString("en", { month: "short", day: "numeric", year: "numeric" })} · {featured.data.author}
          </span>
        </div>
        <a class="button secondary" href={`/blog/${featured.id}`}>Read article</a>
      </article>
    </section>
  ) : null}

  <section>
    <div class="section-heading inline-heading">
      <div>
        <p class="eyebrow">Recent</p>
        <h2>More from the blog</h2>
      </div>
      <a href="/blog">View all →</a>
    </div>
    <div class="post-list two-col">
      {secondary.map((post) => (
        <article class="post-card">
          <div class="tag-row">
            {post.data.tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
          </div>
          <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
          <span class="post-meta">
            {new Date(post.data.pubDate).toLocaleDateString("en", { month: "short", day: "numeric", year: "numeric" })} · {post.data.author}
          </span>
          <p>{post.data.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
